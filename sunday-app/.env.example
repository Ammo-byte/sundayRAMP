# Primary backend URL for the app.
# Hosted example:
EXPO_PUBLIC_API_BASE_URL=https://your-app.railway.app

# Optional local or Tailscale fallbacks.
EXPO_PUBLIC_API_FALLBACK_URLS=http://192.168.x.x:8000,http://your-mac.local:8000,http://100.x.y.z:8000

# Match SUNDAY_API_KEY (or legacy CRON_SECRET) on the backend if protected.
EXPO_PUBLIC_API_TOKEN=your_backend_api_token_here

# If you want to use a local Mac backend instead, replace EXPO_PUBLIC_API_BASE_URL with:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:8000
